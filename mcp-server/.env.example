# Arcent Agent MCP — Local Environment Variables
# Copy this file to .env and fill in your values
# (.env is gitignored — never commit your real keys)
#
# This MCP SIGNS NOTHING: every tool returns an unsigned tx your harness signs.
# There is NO wallet private key here. The only secret it reads is
# PLAYER_SESSION_SEED (ZK mental-poker decrypt — cannot move funds).

# --- RPC (Arc Testnet; default works for most users) ------------------------
ARC_READ_RPC_URL=https://rpc.testnet.arc.network
ARC_TX_RPC_URL=https://rpc.testnet.arc.network
# Arc chain id (defaults to testnet 5042002; set for other Arc networks).
# ARC_CHAIN_ID=5042002

# --- ZK session seed (REQUIRED for the poker decrypt tools) ------------------
# 256-bit hex. Derives your BabyJubJub session key for card decryption ONLY —
# it can NOT sign or move funds. Read from env, never a tool arg, so it never
# crosses the JSON-RPC boundary into LLM-visible context.
PLAYER_SESSION_SEED=replace-with-your-256-bit-hex-zk-session-seed

# --- Contract addresses (REQUIRED — NO hardcoded defaults, they drift) -------
#
# Addresses change on every redeploy. DO NOT hardcode them here — the single
# source of truth is the main AgenticZK repo's `.mcp.json.example`, which is
# auto-generated from `packages/contracts/deployments/<chainId>/latest.json`.
# Copy the full env block from there (or run this MCP as a child of that config):
#   https://github.com/0xAiBRN/agenticzk/blob/main/.mcp.json.example
#
# The set the MCP reads from env (see mcp-server/src/config.ts):
#   USDC_ADDRESS, IDENTITY_REGISTRY, VALIDATION_REGISTRY,
#   POKER_ORCHESTRATOR, POKER_TABLE_SYSTEM, POKER_BET_SYSTEM, POKER_DEAL_SYSTEM,
#   POKER_DECRYPT_SYSTEM, POKER_SHOWDOWN_SYSTEM, POKER_SHOWDOWN_INVOKER,
#   POKER_HAND_FLOW_ROUTER, POKER_CARD_POINT_LOOKUP,
#   SHUFFLE_FIRST_VERIFIER, SHUFFLE_MID_VERIFIER, SHUFFLE_LAST_VERIFIER,
#   DECK_COMMIT_VERIFIER, DECRYPT_VERIFIER,
#   POKER_PROTOCOL_REGISTRY (HC#11 version gate; blank = local/testnet bootstrap)

# --- ZK artifacts (REQUIRED for the poker shuffle/decrypt tools) -------------
#
# Set ZK_ARTIFACTS_DIR to the circuits build/ directory; every artifact path is
# derived from it. Or set each ZK_* path explicitly to override.
# There is NO machine-specific default — a public clone must set this.
ZK_ARTIFACTS_DIR=/path/to/agenticzk/packages/circuits/build
# The shuffle uses four circuits (round-specific first/mid/last + a deck_commit
# DA-fault circuit). Override any path individually; otherwise resolved from
# ZK_ARTIFACTS_DIR.
# ZK_SHUFFLE_FIRST_ZKEY=
# ZK_SHUFFLE_FIRST_WASM=
# ZK_SHUFFLE_MID_ZKEY=
# ZK_SHUFFLE_MID_WASM=
# ZK_SHUFFLE_LAST_ZKEY=
# ZK_SHUFFLE_LAST_WASM=
# ZK_DECK_COMMIT_ZKEY=
# ZK_DECK_COMMIT_WASM=
# ZK_DECRYPT_ZKEY=
# ZK_DECRYPT_WASM=

# ZK prover backend: "snarkjs" (default, JS, ~20s/proof) or "rapidsnark"
# (C++ native, ~3-4s/proof). ZK_RAPIDSNARK_BIN is REQUIRED only when
# ZK_PROVER_BACKEND=rapidsnark.
# ZK_PROVER_BACKEND=snarkjs
# ZK_RAPIDSNARK_BIN=/path/to/rapidsnark/package/bin/prover
